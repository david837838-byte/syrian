FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
ADMIN_PASSWORD=replace-with-admin-password

DATABASE_PATH=database.db
BACKUP_FOLDER=backups

ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
TRUSTED_ORIGIN_HOSTS=your-domain.com,www.your-domain.com
DEFAULT_COUNTRY_CODE=SY

MAIL_SERVER=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=noreply@your-domain.com
MAIL_PASSWORD=replace-with-mail-password
MAIL_DEFAULT_SENDER=noreply@your-domain.com
MAIL_SENDER_NAME=منصة الاستثمار الذكية الآمنة

GOOGLE_CLIENT_ID=

RATELIMIT_STORAGE_URL=memory://
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io
TATUM_ETH_TESTNET_TYPE=ethereum-sepolia
REAL_WALLET_XPUB_TRON=
REAL_WALLET_XPUB_ETHEREUM=
REAL_WALLET_XPUB_BSC=
REAL_WALLET_XPUB_BITCOIN=
